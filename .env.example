# ============================================
# Evolution API (WhatsApp) — opcional
# Sin configurar, el envío de facturas por WhatsApp devuelve 503.
# EVOLUTION_API_URL: URL base de tu instancia, p.ej. https://evolution.midominio.com
# EVOLUTION_API_KEY: apikey global de la instancia
# EVOLUTION_INSTANCE: nombre de la instancia conectada al número emisor
# ============================================
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# ============================================
